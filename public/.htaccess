<IfModule mod_mime.c>
  AddType application/xml;charset=utf-8 .xml
  AddType application/xslt+xml;charset=utf-8 .xsl
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect legacy query language URLs to clean paths
  RewriteCond %{QUERY_STRING} ^lang=(ru|uz)$ [NC]
  RewriteCond %{HTTP_HOST} ^(www\.)?ferfer\.pharmevo\.uz$ [NC]
  RewriteRule ^$ https://ferfer.pharmevo.uz/%1? [L,R=301]

  # Redirect root to default language (no query string, no www check needed here)
  RewriteRule ^$ https://ferfer.pharmevo.uz/ru [L,R=301]

  # Force non-www canonical domain
  RewriteCond %{HTTP_HOST} ^www\.ferfer\.pharmevo\.uz$ [NC]
  RewriteRule ^(.*)$ https://ferfer.pharmevo.uz/$1 [L,R=301]

  # SPA fallback: serve index.html for client-routed URLs
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

